# GitHub personal access token — no scopes needed for reading public profiles,
# but a token bumps your GraphQL rate limit from 60/hr to 5000/hr.
# Create one at https://github.com/settings/tokens
GITHUB_TOKEN=

# Redis Cloud connection string (Vercel's default "Redis" marketplace option).
# Caches cards for 6 hours so repeat views don't burn your GitHub rate limit.
# Format: redis://default:PASSWORD@HOST:PORT
# Get this from your database's Connect panel in the Vercel Storage tab,
# or directly from the Redis Cloud console.
REDIS_URL=
